{
  "layer": "top",
  "position": "bottom",
  "spacing": 0,
  "height": 30,
  "modules-left": [
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-right": [
    "wireplumber",
    "network",
    "cpu",
    "memory",
    "clock",
    "tray"
  ],
  "tray": {
    "spacing": 10
  },
  "clock": {
    "format": "{:%H:%M:%S %d-%m-%Y}",
    "interval": 1
  },
  "cpu": {
    "format": "cpu {usage}%",
    "tooltip": false,
    "interval": 2
  },
  "memory": {
    "format": "mem {}%",
    "interval": 2
  },
  "network": {
    "format-ethernet": "eth {ipaddr}/{cidr}",
    "tooltip-format": "{ifname} via {gwaddr}",
    "format-linked": "{ifname} (no ip)",
    "format-disconnected": "eth disconnected"
  },
  "wireplumber": {
    "format": "vol {volume}%",
    "format-muted": "muted",
    "scroll-step": 5.0,
    "on-click": "pavucontrol",
    "on-click-right": "qpwgraph",
    "max-volume": 150
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "·",
      "urgent": "!"
    }
  }
}
